{
  "id": "neutral-base",
  "name": "Neutral Base",
  "description": "Portable neutral base: primitive grayscale colors with a semantic surface role and a small primitive spacing scale.",
  "version": "1.0.0",
  "includedCategories": ["color", "spacing"],
  "tokens": {
    "color": {
      "$type": "color",
      "$extensions": {
        "ar.neuraz.design-system-manager": {
          "foundation": { "level": "primitive" }
        }
      },
      "gray": {
        "100": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.961, 0.961, 0.961],
            "alpha": 1,
            "hex": "#f5f5f5"
          }
        },
        "900": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.102, 0.102, 0.102],
            "alpha": 1,
            "hex": "#1a1a1a"
          }
        }
      },
      "surface": {
        "$extensions": {
          "ar.neuraz.design-system-manager": {
            "foundation": { "level": "semantic" }
          }
        },
        "default": { "$value": "{color.gray.100}" }
      }
    },
    "spacing": {
      "$type": "dimension",
      "$extensions": {
        "ar.neuraz.design-system-manager": {
          "foundation": { "level": "primitive" }
        }
      },
      "100": { "$value": { "value": 4, "unit": "px" } },
      "200": { "$value": { "value": 8, "unit": "px" } }
    }
  }
}
