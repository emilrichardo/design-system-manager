{
  "id": "neutral-base",
  "name": "Neutral Base",
  "description": "Portable neutral base: primitive grayscale colors with a semantic surface role and a small primitive spacing scale.",
  "version": "1.0.0",
  "includedCategories": ["color", "spacing"],
  "tokens": {
    "color": {
      "gray": {
        "100": {
          "$type": "color",
          "$extensions": { "ar.neuraz.design-system-manager": { "foundation": { "level": "primitive" } } },
          "$value": { "colorSpace": "srgb", "components": [0.961, 0.961, 0.961], "alpha": 1, "hex": "#f5f5f5" }
        },
        "900": {
          "$type": "color",
          "$extensions": { "ar.neuraz.design-system-manager": { "foundation": { "level": "primitive" } } },
          "$value": { "colorSpace": "srgb", "components": [0.102, 0.102, 0.102], "alpha": 1, "hex": "#1a1a1a" }
        }
      },
      "surface": {
        "default": {
          "$type": "color",
          "$extensions": { "ar.neuraz.design-system-manager": { "foundation": { "level": "semantic" } } },
          "$value": "{color.gray.100}"
        }
      }
    },
    "spacing": {
      "100": {
        "$type": "dimension",
        "$extensions": { "ar.neuraz.design-system-manager": { "foundation": { "level": "primitive" } } },
        "$value": { "value": 4, "unit": "px" }
      },
      "200": {
        "$type": "dimension",
        "$extensions": { "ar.neuraz.design-system-manager": { "foundation": { "level": "primitive" } } },
        "$value": { "value": 8, "unit": "px" }
      }
    }
  }
}
