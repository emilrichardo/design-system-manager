{
  "color": {
    "gray": {
      "100": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.2, 0.5, 0.9], "alpha": 1, "hex": "#3b82f6" } }
    },
    "surface": {
      "default": { "$type": "color", "$value": "{color.gray.100}" }
    }
  },
  "spacing": {
    "100": { "$type": "dimension", "$value": { "value": 4, "unit": "px" } }
  },
  "opacity": {
    "low": { "$type": "number", "$value": 0.5 }
  }
}
