{
  "name": "@neuraz/design-system-manager",
  "version": "0.1.0",
  "description": "Gestor local de Design Systems distribuido como paquete npm (fase de especificación).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "neuraz-ds": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "presets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "node scripts/arch-guard.mjs",
    "neuraz-ds": "node dist/cli/index.js"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "ajv": "^8.17.1",
    "commander": "^14.0.0",
    "semver": "^7.7.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/semver": "^7.7.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
